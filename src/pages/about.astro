---
import BaseLayout from "../layouts/BaseLayout.astro";

const aboutAnimationImage = "/images/about-animation.png";
const travelSceneImage = "/images/about-travel-scene.jpg";

const siteUrl = "https://50beautifulplaces.com";
const aboutUrl = `${siteUrl}/about/`;
const aboutDescription =
  "Why 50 Beautiful Places was created: a personal travel project focused on awe-inspiring landscapes, meaningful travel experiences, cultural depth, and practical destination guidance.";
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "@id": `${aboutUrl}#aboutpage`,
    name: "About 50 Beautiful Places",
    url: aboutUrl,
    description: aboutDescription,
    isPartOf: { "@type": "WebSite", "@id": `${siteUrl}/#website` },
    about: { "@type": "Organization", "@id": `${siteUrl}/#organization` }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
      { "@type": "ListItem", position: 2, name: "About", item: aboutUrl }
    ]
  }
];
---

<BaseLayout
  title="About Me | 50 Beautiful Places"
  description="Learn why 50 Beautiful Places was created: a personal travel project focused on awe-inspiring landscapes, meaningful travel experiences, cultural depth, and practical destination guidance."
  image={aboutAnimationImage}
  imageAlt="Animated travel scene for 50 Beautiful Places"
  preloadImage
  jsonLd={jsonLd}
>
  <!-- Top artwork -->
  <figure class="grid min-h-[calc(100svh-4.6rem)] w-full items-start justify-items-center bg-[#f5f0e8] px-4 py-6">
    <img
      src={aboutAnimationImage}
      alt="Animated travel scene for 50 Beautiful Places"
      width="1024" height="1536"
      fetchpriority="high"
      class="h-auto max-h-[calc(100svh-7rem)] w-auto max-w-full object-contain shadow-card"
    />
  </figure>

  <!-- Intro prose -->
  <section class="mx-auto w-full max-w-[1180px] px-4 pt-[clamp(3rem,7vw,5rem)]">
    <p class="mb-3 text-[0.76rem] font-black uppercase tracking-[0.1em] text-clay-text">About Me</p>
    <h1 class="max-w-[11ch] text-forest">Why I created 50 Beautiful Places</h1>
    <p class="mt-5 max-w-[42rem] text-[clamp(1.1rem,2vw,1.35rem)] text-muted">
      I created 50 Beautiful Places because I have spent much of my life searching for places that create a genuine sense of awe.
    </p>
  </section>

  <section class="prose mx-auto w-full max-w-[760px] px-4 pt-[clamp(2rem,5vw,4rem)]">
    <h2>A Life Shaped by Travel</h2>
    <p>
      Not just famous landmarks or luxury resorts, but the kinds of places that stay in your memory for years.
      Places where landscapes feel almost unreal, where cultures are deeply rooted, and where travel still feels
      like discovery rather than consumption.
    </p>
    <p>
      Over the years I have travelled extensively across Africa, Asia, Latin America, Europe, Oceania, and the
      Middle East. I am especially drawn to dramatic natural scenery, remote regions, mountain landscapes, deserts,
      coastlines, ancient cultures, and destinations that still retain a strong local identity.
    </p>
    <p>
      I tend to avoid large cities and instead look for places that feel visually powerful, emotionally memorable,
      and deeply connected to nature or history.
    </p>
  </section>

  <!-- Feature band -->
  <section class="mx-auto w-full max-w-[1180px] px-4 py-[clamp(2rem,5vw,4rem)]" aria-label="What 50 Beautiful Places values">
    <div class="grid gap-4 sm:grid-cols-3">
      <article class="rounded-xl border border-line bg-surface p-6 shadow-card">
        <h2 class="mb-3 max-w-none text-[clamp(1.35rem,2vw,1.75rem)]">Natural Beauty</h2>
        <p class="text-muted">Mountains, deserts, coastlines, islands, wildlife, and dramatic landscapes that create a true sense of awe.</p>
      </article>
      <article class="rounded-xl border border-line bg-surface p-6 shadow-card">
        <h2 class="mb-3 max-w-none text-[clamp(1.35rem,2vw,1.75rem)]">Cultural Depth</h2>
        <p class="text-muted">Places with history, architecture, local identity, ancient traditions, and a strong sense of place.</p>
      </article>
      <article class="rounded-xl border border-line bg-surface p-6 shadow-card">
        <h2 class="mb-3 max-w-none text-[clamp(1.35rem,2vw,1.75rem)]">Practical Travel Intelligence</h2>
        <p class="text-muted">Clear guidance on when to go, how realistic a trip is, what it costs, and whether a place truly lives up to expectations.</p>
      </article>
    </div>
  </section>

  <!-- Personal travel image -->
  <figure class="mx-auto w-full max-w-[1180px] px-4 pb-[clamp(2rem,5vw,4rem)]">
    <img
      src={travelSceneImage}
      alt="Expedition vehicles and a traveler on a wide salt flat at dusk"
      width="1600" height="900"
      loading="lazy"
      decoding="async"
      class="aspect-[2.25/1] w-full rounded-xl object-cover shadow-card"
    />
    <figcaption class="mt-2 text-xs text-muted">Danakil Depression, Ethiopia</figcaption>
  </figure>

  <!-- Extended prose -->
  <section class="prose mx-auto w-full max-w-[760px] px-4 pb-[clamp(2rem,5vw,4rem)]">
    <h2>What Makes a Place Beautiful?</h2>
    <p>
      This website is the result of decades of travel research, planning, photography inspiration, and personal
      curiosity. It combines destinations I have visited myself with places I have spent years researching and
      dreaming about. The aim is not simply to create another top destinations list, but to build a curated
      collection of places that genuinely inspire wonder.
    </p>
    <p>Many travel websites focus heavily on luxury, nightlife, influencers, or fast-moving itineraries. My focus is different. I care about:</p>
    <ul>
      <li>Extraordinary landscapes</li>
      <li>Visual beauty</li>
      <li>Meaningful travel experiences</li>
      <li>Photography-worthy scenery</li>
      <li>Strong cultural atmosphere</li>
      <li>Adventure and exploration</li>
      <li>Places that feel emotionally unforgettable</li>
    </ul>

    <h2>Why This Website Exists</h2>
    <p>
      I also care deeply about practical travel intelligence. I enjoy researching how destinations actually work
      in real life: when to go, how difficult they are to reach, what they truly cost, how crowded they are, and
      whether they genuinely live up to their reputation.
    </p>
    <p>
      You will notice that this site includes destinations ranging from iconic world-famous locations to remote
      places that many travellers have never heard of. That balance is intentional.
    </p>
  </section>

  <!-- Sister site live frame -->
  <section class="mx-auto w-full max-w-[1180px] px-4 pb-[clamp(2rem,5vw,4rem)]" aria-labelledby="sister-site-heading">
    <div class="border-t border-line pt-[clamp(2rem,5vw,3rem)]">
      <a
        id="sister-site-heading"
        class="inline-flex text-[clamp(1.5rem,3vw,2.35rem)] font-serif leading-tight text-forest underline decoration-clay/35 underline-offset-8 transition-colors hover:text-clay-text"
        href="https://50difficultplaces.com/"
        target="_blank"
        rel="noopener noreferrer"
      >
        The Sister Site
      </a>
      <div class="mt-6 overflow-hidden rounded-xl border border-line bg-surface shadow-card">
        <iframe
          src="https://50difficultplaces.com/"
          title="The Sister Site: 50 Difficult Places"
          class="h-[min(72svh,760px)] w-full"
          loading="lazy"
          referrerpolicy="strict-origin-when-cross-origin"
        ></iframe>
      </div>
    </div>
  </section>

  <section class="prose mx-auto w-full max-w-[760px] px-4 pb-[clamp(2rem,5vw,4rem)]">
    <h2>How I Choose Places</h2>
    <p>
      Professionally, I come from an analytical background, which influences how I approach travel research and
      trip planning. Personally, I am also deeply interested in endurance sports, hiking, outdoor landscapes,
      photography, and long-term exploration.
    </p>

    <h2>The Purpose of 50 Beautiful Places</h2>
    <p>
      The goal of this site is simple: to help people discover places that create real excitement, wonder, and
      inspiration, and to make those places feel achievable rather than overwhelming.
    </p>
    <p>
      If a destination on this website causes someone to pause, dream, plan an adventure, or see the world
      differently, then the project is succeeding.
    </p>
  </section>

  <!-- CTA -->
  <section class="mx-auto w-full max-w-[1180px] px-4 pb-[clamp(3rem,7vw,6rem)]">
    <div class="rounded-2xl bg-forest px-[clamp(2rem,6vw,4rem)] py-[clamp(2rem,5vw,3.5rem)] text-cream">
      <p class="mb-3 text-[0.76rem] font-black uppercase tracking-[0.1em] text-sun">Begin the atlas</p>
      <h2 class="max-w-none text-cream">Start exploring beautiful places</h2>
      <p class="mt-3 max-w-[46rem] text-[1.05rem] text-cream/80">
        Browse the collection and discover destinations that inspire wonder, curiosity, and a real desire to travel.
      </p>
      <a
        class="mt-7 inline-flex min-h-[2.9rem] items-center justify-center rounded-full bg-cream px-6 text-sm font-extrabold text-forest transition-opacity hover:opacity-90"
        href="/places/"
      >Explore Places</a>
    </div>
  </section>
</BaseLayout>
