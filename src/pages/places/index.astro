---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import DestinationCard from "../../components/DestinationCard.astro";

const destinations = (await getCollection("destinations")).sort((a, b) => a.data.title.localeCompare(b.data.title));
const regions = [...new Set(destinations.map((place) => place.data.region))].sort();
const bestForOptions = [...new Set(destinations.flatMap((place) => place.data.bestFor))].sort();
---

<BaseLayout
  title="Fifty Places Worth Crossing a Continent For"
  description="A handpicked atlas of the world's most extraordinary destinations, from salt flats and ancient mosques to overgrown ruins and quiet beaches almost nobody finds."
  image={destinations[0].data.mainImage}
>
  <section class="page-hero compact">
    <h1>Fifty places <br />worth crossing <br />a continent for.</h1>
    <p>A handpicked atlas of the world's most extraordinary destinations &mdash; from salt flats and ancient mosques to overgrown ruins and quiet beaches almost nobody finds.</p>
  </section>

  <section class="filter-strip" aria-label="Regions">
    <a href="/places/" data-region-filter="all">All</a>
    {regions.map((region) => (
      <a href={`/places/?region=${encodeURIComponent(region)}`} data-region-filter={region}>{region}</a>
    ))}
  </section>

  <section class="filter-strip secondary-filter" aria-label="Best for">
    <span>Best for</span>
    <a href="/places/" data-best-for-filter="all">All</a>
    {bestForOptions.map((category) => (
      <a href={`/places/?bestFor=${encodeURIComponent(category)}`} data-best-for-filter={category}>{category}</a>
    ))}
  </section>

  <section class="section">
    <div class="destination-grid">
      {destinations.map((place, index) => (
        <DestinationCard
          href={`/places/${place.id}/`}
          title={place.data.title}
          country={place.data.country}
          region={place.data.region}
          summary={place.data.summary}
          image={place.data.mainImage}
          alt={place.data.imageAlt}
          tags={place.data.tags}
          bestFor={place.data.bestFor}
          priority={index < 6}
        />
      ))}
    </div>
  </section>

  <script>
    let activeRegion = new URLSearchParams(window.location.search).get("region");
    let activeBestFor = new URLSearchParams(window.location.search).get("bestFor");
    const cards = document.querySelectorAll("[data-region]");
    const filters = document.querySelectorAll("[data-region-filter]");
    const bestForFilters = document.querySelectorAll("[data-best-for-filter]");

    const applyFilter = () => {
      cards.forEach((card) => {
        const regionMatch = !activeRegion || card.getAttribute("data-region") === activeRegion;
        const bestForValues = card.getAttribute("data-best-for")?.split("|") ?? [];
        const bestForMatch = !activeBestFor || bestForValues.includes(activeBestFor);
        card.toggleAttribute("hidden", !(regionMatch && bestForMatch));
      });

      filters.forEach((filter) => {
        const filterRegion = filter.getAttribute("data-region-filter");
        const isAll = filterRegion === "all";
        if ((isAll && !activeRegion) || filterRegion === activeRegion) {
          filter.setAttribute("aria-current", "page");
        } else {
          filter.removeAttribute("aria-current");
        }
      });

      bestForFilters.forEach((filter) => {
        const filterValue = filter.getAttribute("data-best-for-filter");
        const isAll = filterValue === "all";
        if ((isAll && !activeBestFor) || filterValue === activeBestFor) {
          filter.setAttribute("aria-current", "page");
        } else {
          filter.removeAttribute("aria-current");
        }
      });
    };

    filters.forEach((filter) => {
      filter.addEventListener("click", (event) => {
        event.preventDefault();
        const filterRegion = filter.getAttribute("data-region-filter");
        activeRegion = filterRegion === "all" ? null : filterRegion;
        const params = new URLSearchParams();
        if (activeRegion) params.set("region", activeRegion);
        if (activeBestFor) params.set("bestFor", activeBestFor);
        const nextUrl = params.toString() ? `/places/?${params.toString()}` : "/places/";
        window.history.pushState({}, "", nextUrl);
        applyFilter();
      });
    });

    bestForFilters.forEach((filter) => {
      filter.addEventListener("click", (event) => {
        event.preventDefault();
        const filterValue = filter.getAttribute("data-best-for-filter");
        activeBestFor = filterValue === "all" ? null : filterValue;
        const params = new URLSearchParams();
        if (activeRegion) params.set("region", activeRegion);
        if (activeBestFor) params.set("bestFor", activeBestFor);
        const nextUrl = params.toString() ? `/places/?${params.toString()}` : "/places/";
        window.history.pushState({}, "", nextUrl);
        applyFilter();
      });
    });

    window.addEventListener("popstate", () => {
      activeRegion = new URLSearchParams(window.location.search).get("region");
      activeBestFor = new URLSearchParams(window.location.search).get("bestFor");
      applyFilter();
    });

    applyFilter();
  </script>
</BaseLayout>
