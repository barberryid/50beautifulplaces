---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import DestinationCard from "../../components/DestinationCard.astro";

const destinations = (await getCollection("destinations")).sort((a, b) => a.data.title.localeCompare(b.data.title));
const regions = [...new Set(destinations.map((place) => place.data.region))].sort();
const bestForOptions = [...new Set(destinations.flatMap((place) => place.data.bestFor))].sort();

const siteUrl = "https://50beautifulplaces.com";
const placesUrl = `${siteUrl}/places/`;
const collectionJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${placesUrl}#collection`,
  name: "Fifty Places Worth Crossing a Continent For",
  description:
    "A handpicked atlas of the world's most extraordinary destinations, from salt flats and ancient mosques to overgrown ruins and quiet beaches almost nobody finds.",
  url: placesUrl,
  isPartOf: { "@type": "WebSite", "@id": `${siteUrl}/#website` },
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: destinations.length,
    itemListElement: destinations.map((place, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: `${siteUrl}/places/${place.id}/`,
      name: place.data.title
    }))
  }
};
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
    { "@type": "ListItem", position: 2, name: "Places", item: placesUrl }
  ]
};
const jsonLd = [collectionJsonLd, breadcrumbJsonLd];
---

<BaseLayout
  title="Fifty Places Worth Crossing a Continent For"
  description="A handpicked atlas of the world's most extraordinary destinations, from salt flats and ancient mosques to overgrown ruins and quiet beaches almost nobody finds."
  image={destinations[0].data.mainImage}
  imageAlt={destinations[0].data.imageAlt}
  jsonLd={jsonLd}
>
  <!-- Page hero -->
  <section class="mx-auto w-full max-w-[1180px] px-4 py-[clamp(3rem,8vw,7rem)] pb-8">
    <h1 class="max-w-[12ch]">Fifty places <br />worth crossing <br />a continent for.</h1>
    <p class="mt-4 max-w-[45rem] text-lg text-muted">
      A handpicked atlas of the world's most extraordinary destinations &mdash;
      from salt flats and ancient mosques to overgrown ruins and quiet beaches almost nobody finds.
    </p>
    <p class="mt-5 text-sm font-bold text-muted">
      Prefer a simple list? <a class="text-clay-text underline underline-offset-4 hover:no-underline" href="/all-destinations/">Open All Destinations</a>.
    </p>
  </section>

  <!-- Region filter -->
  <div class="mx-auto w-full max-w-[1180px] px-4 pb-2">
    <div class="flex flex-wrap gap-2" aria-label="Regions">
      <a
        href="/places/"
        data-region-filter="all"
        class="inline-flex min-h-[2.5rem] items-center rounded-full border border-line bg-surface px-4 text-sm font-bold text-muted transition-colors hover:border-forest hover:text-ink"
      >All</a>
      {regions.map((region) => (
        <a
          href={`/places/?region=${encodeURIComponent(region)}`}
          data-region-filter={region}
          class="inline-flex min-h-[2.5rem] items-center rounded-full border border-line bg-surface px-4 text-sm font-bold text-muted transition-colors hover:border-forest hover:text-ink"
        >{region}</a>
      ))}
    </div>
  </div>

  <!-- Best-for filter -->
  <div class="mx-auto w-full max-w-[1180px] px-4 pb-8 pt-3">
    <div class="flex flex-wrap items-center gap-2" aria-label="Best for">
      <span class="text-sm font-black text-forest">Best for</span>
      <a
        href="/places/"
        data-best-for-filter="all"
        class="inline-flex min-h-[2.5rem] items-center rounded-full border border-line bg-surface px-4 text-sm font-bold text-muted transition-colors hover:border-forest hover:text-ink"
      >All</a>
      {bestForOptions.map((category) => (
        <a
          href={`/places/?bestFor=${encodeURIComponent(category)}`}
          data-best-for-filter={category}
          class="inline-flex min-h-[2.5rem] items-center rounded-full border border-line bg-surface px-4 text-sm font-bold text-muted transition-colors hover:border-forest hover:text-ink"
        >{category}</a>
      ))}
    </div>
  </div>

  <!-- Grid -->
  <section class="mx-auto w-full max-w-[1180px] px-4 pb-[clamp(3rem,7vw,6rem)]">
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {destinations.map((place, index) => (
        <DestinationCard
          href={`/places/${place.id}/`}
          title={place.data.title}
          country={place.data.country}
          region={place.data.region}
          summary={place.data.summary}
          image={place.data.mainImage}
          alt={place.data.imageAlt}
          tags={place.data.tags}
          bestTime={place.data.bestTime}
          bestFor={place.data.bestFor}
          priority={index < 6}
        />
      ))}
    </div>
  </section>

  <script>
    let activeRegion = new URLSearchParams(window.location.search).get("region");
    let activeBestFor = new URLSearchParams(window.location.search).get("bestFor");
    const cards = document.querySelectorAll("[data-region]");
    const filters = document.querySelectorAll("[data-region-filter]");
    const bestForFilters = document.querySelectorAll("[data-best-for-filter]");

    const applyFilter = () => {
      cards.forEach((card) => {
        const regionMatch = !activeRegion || card.getAttribute("data-region") === activeRegion;
        const bestForValues = card.getAttribute("data-best-for")?.split("|") ?? [];
        const bestForMatch = !activeBestFor || bestForValues.includes(activeBestFor);
        card.toggleAttribute("hidden", !(regionMatch && bestForMatch));
      });
      filters.forEach((filter) => {
        const filterRegion = filter.getAttribute("data-region-filter");
        const isAll = filterRegion === "all";
        if ((isAll && !activeRegion) || filterRegion === activeRegion) {
          filter.setAttribute("aria-current", "page");
        } else {
          filter.removeAttribute("aria-current");
        }
      });
      bestForFilters.forEach((filter) => {
        const filterValue = filter.getAttribute("data-best-for-filter");
        const isAll = filterValue === "all";
        if ((isAll && !activeBestFor) || filterValue === activeBestFor) {
          filter.setAttribute("aria-current", "page");
        } else {
          filter.removeAttribute("aria-current");
        }
      });
    };

    filters.forEach((filter) => {
      filter.addEventListener("click", (event) => {
        event.preventDefault();
        const filterRegion = filter.getAttribute("data-region-filter");
        activeRegion = filterRegion === "all" ? null : filterRegion;
        const params = new URLSearchParams();
        if (activeRegion) params.set("region", activeRegion);
        if (activeBestFor) params.set("bestFor", activeBestFor);
        window.history.pushState({}, "", params.toString() ? `/places/?${params}` : "/places/");
        applyFilter();
      });
    });
    bestForFilters.forEach((filter) => {
      filter.addEventListener("click", (event) => {
        event.preventDefault();
        const filterValue = filter.getAttribute("data-best-for-filter");
        activeBestFor = filterValue === "all" ? null : filterValue;
        const params = new URLSearchParams();
        if (activeRegion) params.set("region", activeRegion);
        if (activeBestFor) params.set("bestFor", activeBestFor);
        window.history.pushState({}, "", params.toString() ? `/places/?${params}` : "/places/");
        applyFilter();
      });
    });
    window.addEventListener("popstate", () => {
      activeRegion = new URLSearchParams(window.location.search).get("region");
      activeBestFor = new URLSearchParams(window.location.search).get("bestFor");
      applyFilter();
    });
    applyFilter();
  </script>
</BaseLayout>
