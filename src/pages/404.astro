---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page Not Found"
  description="The page could not be found. Explore the destination guides on 50 Beautiful Places."
>
  <section class="page-hero compact">
    <p class="eyebrow">404</p>
    <h1>This path has wandered off.</h1>
