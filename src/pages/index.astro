---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import DestinationCard from "../components/DestinationCard.astro";
import { getDestinationImageMetadata } from "../lib/destinationImages";

const destinations = await getCollection("destinations");
const featured = destinations.filter((place) => place.data.featured);
const regions = [...new Set(destinations.map((place) => place.data.region))].sort();
const homeHeroImage = "/images/home-hero-pawel-wieladek-unsplash.jpg";
const homeHeroAlt = "Rocky tropical beach with trees and coastal plants";

const siteUrl = "https://50beautifulplaces.com";
const organizationJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${siteUrl}/#organization`,
  name: "50 Beautiful Places",
  url: `${siteUrl}/`,
  logo: `${siteUrl}/og-default.png`,
  description:
    "Image-led travel inspiration and practical destination guides for beautiful places around the world."
};
const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteUrl}/#website`,
  name: "50 Beautiful Places",
  url: `${siteUrl}/`,
  description:
    "A fast, image-led travel inspiration site for discovering beautiful places, scenic routes, and practical destination notes.",
  inLanguage: "en",
  publisher: { "@id": `${siteUrl}/#organization` }
};
const jsonLd = [organizationJsonLd, websiteJsonLd];
---

<BaseLayout
  title="50 Beautiful Places"
  description="A fast, image-led travel inspiration site for discovering beautiful places, scenic routes, and practical destination notes."
  image={homeHeroImage}
  imageAlt={homeHeroAlt}
  preloadImage
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="hero grid min-h-[calc(100svh-4.6rem)] items-end bg-forest">
    <img
      src={homeHeroImage}
      alt={homeHeroAlt}
      width="1600" height="1000"
      fetchpriority="high"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <p class="absolute bottom-4 right-4 z-10 max-w-[min(24rem,calc(100%-2rem))] rounded bg-ink/60 px-3 py-2 text-xs font-semibold text-cream/90 backdrop-blur-sm">
      Photo by <a class="underline underline-offset-2" href="https://unsplash.com/@pawelwieladek?utm_source=unsplash&utm_medium=referral&utm_content=creditCopyText" rel="noopener noreferrer">Paweł Wielądek</a> on <a class="underline underline-offset-2" href="https://unsplash.com/photos/a-rocky-beach-with-trees-and-plants--BktX8dLWGA?utm_source=unsplash&utm_medium=referral&utm_content=creditCopyText" rel="noopener noreferrer">Unsplash</a>
    </p>
    <div class="relative z-10 w-full max-w-[1180px] px-[clamp(1rem,5vw,5rem)] pb-[14vh] text-cream [text-shadow:0_2px_18px_rgba(0,0,0,0.55)]">
      <p class="mb-3 text-[0.76rem] font-black uppercase tracking-[0.1em] text-sun">Curated travel inspiration</p>
      <h1 class="text-cream">50 Beautiful Places</h1>
      <p class="mt-5 max-w-[42rem] text-[clamp(1.05rem,2vw,1.35rem)] text-cream/85">
        Field-guide style stories for landscapes worth planning a trip around: coastlines, mountain lakes, forests, villages, deserts, and long roads.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-4">
        <a
          class="inline-flex min-h-[2.9rem] items-center justify-center rounded-full bg-cream px-6 text-sm font-extrabold text-forest transition-opacity hover:opacity-90"
          href="/places/"
        >Explore places</a>
        <a
          class="inline-flex min-h-[2.9rem] items-center border-b border-cream/40 px-1 text-sm font-extrabold text-cream transition-all hover:border-cream/80"
          href="#featured"
        >Featured guides &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Intro -->
  <section class="mx-auto w-full max-w-[760px] px-4 py-[clamp(3rem,8vw,7rem)]">
    <h2>Built for dreaming first, planning second</h2>
    <p class="mt-4 max-w-[48rem] text-lg text-muted">
      Each guide keeps the essentials close: why the place is beautiful, when to go,
      how long to stay, and what to know before you commit the miles.
    </p>
  </section>

  <!-- Featured destinations -->
  <section class="mx-auto w-full max-w-[1180px] px-4 pb-[clamp(3rem,7vw,6rem)]" id="featured">
    <div class="mb-6 flex items-end justify-between gap-6">
      <div>
        <p class="mb-2 text-[0.76rem] font-black uppercase tracking-[0.1em] text-clay-text">Featured destinations</p>
      </div>
      <a class="shrink-0 text-sm font-black text-clay-text underline underline-offset-4 hover:no-underline" href="/places/">View all &rarr;</a>
    </div>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {featured.map((place, index) => (
        <DestinationCard
          href={`/places/${place.id}/`}
          title={place.data.title}
          country={place.data.country}
          region={place.data.region}
          summary={place.data.summary}
          image={getDestinationImageMetadata(place.id, place.data)}
          tags={place.data.tags}
          bestTime={place.data.bestTime}
          bestFor={place.data.bestFor}
          priority={index < 3}
        />
      ))}
    </div>
  </section>

  <!-- Browse by region -->
  <section class="mx-auto w-full max-w-[1180px] px-4">
    <div class="border-y border-line py-[clamp(2rem,5vw,4rem)]">
      <div class="grid gap-8 lg:grid-cols-[1.1fr_1fr] lg:items-center">
        <div>
          <p class="mb-2 text-[0.76rem] font-black uppercase tracking-[0.1em] text-clay-text">Browse by region</p>
          <h2>Find a landscape that matches the trip</h2>
        </div>
        <div class="flex flex-wrap gap-2">
          {regions.map((region) => (
            <a
              href={`/places/?region=${encodeURIComponent(region)}`}
              class="inline-flex min-h-[2.75rem] items-center rounded-full border border-line bg-surface px-4 text-sm font-bold text-muted transition-colors hover:border-forest hover:text-ink"
            >{region}</a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
