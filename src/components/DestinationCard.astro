---
interface Props {
  href: string;
  title: string;
  country: string;
  region: string;
  summary: string;
  image: string;
  alt: string;
  tags: string[];
  priority?: boolean;
}

const { href, title, country, region, summary, image, alt, tags, priority = false } = Astro.props;
---

<article class="destination-card" data-region={region}>
  <a href={href} aria-label={`Read the ${title} guide`}>
    <img src={image} alt={alt} width="1200" height="900" loading={priority ? "eager" : "lazy"} decoding="async" fetchpriority={priority ? "high" : "auto"} />
    <div class="card-body">
      <p class="eyebrow">{region} / {country}</p>
      <h3>{title}</h3>
      <p>{summary}</p>
      <div class="tag-row" aria-label="Destination tags">
        {tags.slice(0, 3).map((tag) => <span>{tag}</span>)}
      </div>
    </div>
  </a>
</article>
